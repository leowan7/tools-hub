# Required environment variables for the Ranomics tools hub.
# Copy to .env for local dev. Do NOT commit the real .env.

# Supabase project — shared with Epitope Scout.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-publishable-anon-key

# Flask session signing secret (any long random string).
SESSION_SECRET_KEY=change-me-to-a-long-random-string

# Local dev port (optional; defaults to 5000).
PORT=5000
